<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <style>
    .error-page {
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      min-height: 60vh; text-align: center; padding: 40px;
    }
    .error-page h1 { font-size: 80px; color: #00aeee; margin: 0; }
    .error-page p  { font-size: 18px; color: #555; margin: 16px 0 32px; }
    .error-page a  {
      background: #00aeee; color: #fff; padding: 12px 28px;
      border-radius: 4px; text-decoration: none; font-weight: 600;
    }
  </style>
</head>
<body>
  <%- include('partials/shippingBar') %>
  <%- include('partials/header') %>
  <div class="error-page">
    <h1>404</h1>
    <p>Oops — we can't find that page.</p>
    <a href="/">Back to Home</a>
  </div>
  <%- include('partials/footer') %>
  <%- include('partials/scripts') %>
</body>
</html>
