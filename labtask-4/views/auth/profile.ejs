<%# views/auth/profile.ejs — Logged-in user profile page %>
<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
</head>
<body>

  <%- include('../partials/header') %>
  <%- include('../partials/shippingBar') %>

  <div style="max-width:600px; margin:4rem auto; padding:0 1.5rem; font-family:'Poppins',sans-serif;">

    <h1 style="font-size:1.6rem; font-weight:700; margin-bottom:0.3rem;">My Account</h1>
    <p style="color:#888; font-size:0.9rem; margin-bottom:2rem;">Welcome back, <%= user.name %>!</p>

    <% if (success && success.length > 0) { %>
      <div style="background:#f0fff4;color:#1e7e3e;border:1px solid #b2dfdb;
                  padding:0.75rem 1rem;border-radius:6px;margin-bottom:1.5rem;font-size:0.88rem;">
        <%= success[0] %>
      </div>
    <% } %>

    <div style="background:#fff;border:1px solid #eee;border-radius:12px;
                padding:2rem;box-shadow:0 2px 12px rgba(0,0,0,0.06);">

      <div style="display:flex;align-items:center;gap:1.2rem;margin-bottom:1.8rem;">
        <div style="width:56px;height:56px;border-radius:50%;background:#1a1a1a;
                    display:flex;align-items:center;justify-content:center;
                    color:#fff;font-size:1.4rem;font-weight:700;flex-shrink:0;">
          <%= user.name.charAt(0).toUpperCase() %>
        </div>
        <div>
          <div style="font-weight:700;font-size:1.05rem;"><%= user.name %></div>
          <div style="color:#888;font-size:0.85rem;"><%= user.email %></div>
        </div>
      </div>

      <table style="width:100%;border-collapse:collapse;font-size:0.9rem;">
        <tr style="border-bottom:1px solid #f0f0f0;">
          <td style="padding:0.7rem 0;color:#888;width:40%;">Name</td>
          <td style="padding:0.7rem 0;font-weight:500;"><%= user.name %></td>
        </tr>
        <tr style="border-bottom:1px solid #f0f0f0;">
          <td style="padding:0.7rem 0;color:#888;">Email</td>
          <td style="padding:0.7rem 0;font-weight:500;"><%= user.email %></td>
        </tr>
        <tr style="border-bottom:1px solid #f0f0f0;">
          <td style="padding:0.7rem 0;color:#888;">Account Type</td>
          <td style="padding:0.7rem 0;">
            <span style="background:<%= user.role === 'admin' ? '#1a1a1a' : '#f0f0f0' %>;
                         color:<%= user.role === 'admin' ? '#fff' : '#555' %>;
                         padding:0.2rem 0.7rem;border-radius:20px;font-size:0.8rem;
                         font-weight:600;text-transform:capitalize;">
              <%= user.role %>
            </span>
          </td>
        </tr>
        <tr>
          <td style="padding:0.7rem 0;color:#888;">Member Since</td>
          <td style="padding:0.7rem 0;font-weight:500;">
            <%= new Date(user.createdAt).toLocaleDateString('en-PK', { year:'numeric', month:'long', day:'numeric' }) %>
          </td>
        </tr>
      </table>

      <div style="margin-top:1.8rem;display:flex;gap:0.8rem;flex-wrap:wrap;">
        <% if (user.role === 'admin') { %>
          <a href="/admin" style="padding:0.6rem 1.2rem;background:#1a1a1a;color:#fff;
                                  border-radius:6px;text-decoration:none;font-size:0.88rem;
                                  font-weight:600;">
            Admin Panel →
          </a>
        <% } %>
        <a href="/logout" style="padding:0.6rem 1.2rem;background:#f7f7f7;color:#333;
                                 border:1px solid #ddd;border-radius:6px;text-decoration:none;
                                 font-size:0.88rem;font-weight:600;">
          Logout
        </a>
        <a href="/" style="padding:0.6rem 1.2rem;color:#888;border-radius:6px;
                           text-decoration:none;font-size:0.88rem;">
          ← Continue Shopping
        </a>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>
  <%- include('../partials/scripts') %>
</body>
</html>
