<%# views/admin/partials/layout-top.ejs — top of every admin page %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">

<div class="admin-wrapper">

  <!-- ── Sidebar ── -->
  <aside class="admin-sidebar">
    <div class="admin-sidebar-logo">
      <img src="/images/maztonologo.jpg" alt="Mazton">
      <span>Admin Panel</span>
    </div>

    <% if (currentUser) { %>
      <div style="padding:0.5rem 1.2rem 1rem;font-size:0.8rem;color:#aaa;">
        Logged in as <strong style="color:#fff;"><%= currentUser.name %></strong>
      </div>
    <% } %>

    <nav class="admin-nav">
      <ul>
        <li><a href="/admin" class="<%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
          📊 Dashboard
        </a></li>
        <li><a href="/admin/products/new" class="<%= typeof activePage !== 'undefined' && activePage === 'new' ? 'active' : '' %>">
          ➕ Add Product
        </a></li>
        <li class="admin-nav-divider"></li>
        <li><a href="/" target="_blank">🌐 View Site</a></li>
        <li><a href="/profile">👤 My Profile</a></li>
        <li><a href="/logout">🚪 Logout</a></li>
      </ul>
    </nav>

    <%# Flash messages inside admin panel %>
    <% if (typeof flashError !== 'undefined' && flashError && flashError.length > 0) { %>
      <div style="margin:1rem;padding:0.6rem 0.8rem;background:#fff0f0;
                  color:#c0392b;border-radius:6px;font-size:0.8rem;">
        <%= flashError[0] %>
      </div>
    <% } %>
    <% if (typeof flashSuccess !== 'undefined' && flashSuccess && flashSuccess.length > 0) { %>
      <div style="margin:1rem;padding:0.6rem 0.8rem;background:#f0fff4;
                  color:#1e7e3e;border-radius:6px;font-size:0.8rem;">
        <%= flashSuccess[0] %>
      </div>
    <% } %>
  </aside>

  <!-- ── Main content ── -->
  <main class="admin-main">
